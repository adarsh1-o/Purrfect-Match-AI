# --- SMTP EMAIL NOTIFICATION SERVICE CONFIGURATIONS ---
# Host SMTP provider details (e.g. smtp.gmail.com for Gmail, smtp.sendgrid.net for SendGrid)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Your credentials
SMTP_USER=your-email@gmail.com
# For Gmail, this must be a Google App Password (NOT your regular account password)
# Get one here: https://myaccount.google.com/apppasswords
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Sender identity
SENDER_EMAIL=your-email@gmail.com
